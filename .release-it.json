{
    "npm": {
      "publish": true
    },
    "github": {
      "publish": true,
      "release": true
    },
    "git": {
      "requireBranch": "main",
      "commitMessage": "chore: release v${version}"
    },
    "hooks": {
      "before:init": ["git pull --ff-only", "npm run lint", "npm test"],
      "after:bump": ["node bin/verifyRelease.mjs", "npx auto-changelog -p"]
    }
  }
  