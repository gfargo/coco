{
  "name": "git-coco",
  "version": "0.71.0",
  "description": "git-coco — AI git commits, changelogs, code review, and PR/MR creation, plus a terminal workstation. Works on GitHub, GitHub Enterprise, and GitLab; supports OpenAI, Anthropic, Gemini, Mistral, Azure, Bedrock, and local Ollama.",
  "keywords": [
    "git",
    "git-coco",
    "coco",
    "ai",
    "ai-commit",
    "commit-message",
    "conventional-commits",
    "commitlint",
    "changelog",
    "code-review",
    "pull-request",
    "merge-request",
    "github",
    "github-enterprise",
    "gitlab",
    "glab",
    "gh",
    "multi-forge",
    "ollama",
    "local-llm",
    "openai",
    "anthropic",
    "cli",
    "tui",
    "terminal",
    "developer-tools"
  ],
  "author": "gfargo <ghfargo@gmail.com>",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.esm.mjs",
  "files": [
    "dist",
    "!dist/dts"
  ],
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/gfargo/coco#readme",
  "bugs": {
    "url": "https://github.com/gfargo/coco/issues"
  },
  "bin": {
    "coco": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gfargo/coco.git"
  },
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "tsx watch src/index.ts",
    "dev:tui": "tsx src/index.ts",
    "prebuild": "npm run build:schema && npm run build:info",
    "build": "rollup -c",
    "postbuild": "node bin/copyTreeSitterWasm.mjs",
    "build:schema": "tsx bin/generateSchema.ts",
    "build:info": "tsx bin/generateBuildInfo.ts",
    "build:watch": "rollup -c -w",
    "clean": "npx rimraf dist && npx rimraf coverage",
    "lint": "eslint src bin",
    "lint:fix": "eslint --fix src",
    "test": "npm run test:jest && npm run test:publish",
    "test:publish": "npm run lint && npm run build && npm run test:cli && npm pack --dry-run",
    "test:cli": "tsx bin/smokeCli.ts",
    "bench": "tsx bin/benchmark.ts",
    "scenario": "tsx bin/scenarioRunner.ts",
    "screenshot": "tsx bin/screenshot.ts",
    "screenshot:sync": "tsx bin/syncScreenshots.ts",
    "screenshot:sync:all": "tsx bin/syncScreenshots.ts",
    "eval:structural-extract": "tsx bin/structuralExtractEval.ts",
    "pretest:jest": "npm run build:info && node bin/copyTreeSitterWasm.mjs",
    "test:jest": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:jest:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "pretest:unit": "npm run build:info && node bin/copyTreeSitterWasm.mjs",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns=/node_modules/ --testPathIgnorePatterns=integration",
    "pretest:integration": "npm run build:info && node bin/copyTreeSitterWasm.mjs",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPatterns=integration",
    "pretest:coverage": "npm run build:info && node bin/copyTreeSitterWasm.mjs",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "release": "release-it",
    "release:dry-run": "release-it --ci --dry-run --no-git --no-github.release --no-github.publish --no-npm.publish",
    "release:verify": "node bin/verifyRelease.mjs",
    "release:formula": "node bin/genHomebrewFormula.mjs",
    "wiki:clone": "tsx bin/wiki.ts clone",
    "wiki:help": "tsx bin/wiki.ts help",
    "wiki:pull": "tsx bin/wiki.ts pull",
    "wiki:push": "tsx bin/wiki.ts push",
    "wiki:status": "tsx bin/wiki.ts status",
    "prepublishOnly": "npm run clean && npm run build",
    "coco": "npm run coco:ts",
    "coco:ts": "tsx src/index.ts",
    "coco:cjs": "node dist/index.js",
    "coco:esm": "node dist/index.esm.mjs"
  },
  "devDependencies": {
    "@commitlint/types": "^21.0.1",
    "@gfargo/git-scenarios": "^1.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-eslint": "^9.0.5",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/diff": "^8.0.0",
    "@types/ini": "^4.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "@types/react": "19.2.15",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.54.0",
    "eslint-plugin-react-hooks": "4.6.2",
    "ink-testing-library": "4.0.0",
    "jest": "^30.0.5",
    "release-it": "^20.0.1",
    "rollup": "^4.50.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-executable": "^1.6.3",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-preserve-shebangs": "^0.2.0",
    "rollup-plugin-typescript2": "^0.37.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tree-sitter-typescript": "^0.23.2",
    "ts-jest": "^29.1.0",
    "ts-json-schema-generator": "^2.9.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.16.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@commitlint/core": "^21.0.0",
    "@inquirer/prompts": "8.5.2",
    "@langchain/anthropic": "^1.0.0",
    "@langchain/aws": "^1.3.9",
    "@langchain/community": "^1.0.0",
    "@langchain/core": "^1.1.34",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/mistralai": "^1.1.0",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.5",
    "ajv": "^8.18.0",
    "chalk": "4.1.2",
    "diff": "9.0.0",
    "ini": "7.0.0",
    "ink": "7.0.5",
    "minimatch": "^10.2.5",
    "ora": "5.4.1",
    "p-queue": "5.0.0",
    "performance-now": "2.1.0",
    "pretty-ms": "7.0.1",
    "react": "19.2.6",
    "react-devtools-core": "7.0.1",
    "simple-git": "3.36.0",
    "tiktoken": "^1.0.21",
    "web-tree-sitter": "^0.26.8",
    "yargs": "17.7.2"
  },
  "resolutions": {
    "cross-spawn": "7.0.6",
    "brace-expansion": "^5.0.6",
    "@anthropic-ai/sdk": "^0.91.1",
    "ip-address": "^10.1.1",
    "shell-quote": "^1.8.4",
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4"
  }
}
