{
  "compilerOptions": {
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "rootDir": "src",
    "target": "ES2020",
    "module": "esnext",
    "lib": ["esnext"],
    "declaration": true,
    "declarationDir": "dist/dts",
    "sourceMap": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["jest", "node"],
    "paths": {
      "@gfargo/git-scenarios": ["./packages/git-scenarios/src/index.ts"],
      "@gfargo/git-scenarios/*": ["./packages/git-scenarios/src/*"]
    }
  },
  "include": ["src/**/*.ts", "bin/validateSchema.test.ts"],
  "exclude": [
    "node_modules",
    "**/*.spec.ts",
    "**/*.test.ts",
    "dist",
    "rollup.config.mjs",
    "src/**/__evals__/**"
  ]
}
